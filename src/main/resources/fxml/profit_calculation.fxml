<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.ProfitCalculationController">
    <children>
        <Label layoutX="20.0" layoutY="20.0" text="Расчёт прибыли за период">
            <font><Font size="24.0" /></font>
        </Label>

        <VBox layoutX="20.0" layoutY="70.0" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
            <children>
                <Label text="Выберите период:">
                    <font><Font size="14.0" /></font>
                </Label>
                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Дата начала:" />
                            <DatePicker fx:id="dpStartDate" prefWidth="200.0" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Дата окончания:" />
                            <DatePicker fx:id="dpEndDate" prefWidth="200.0" />
                        </VBox>
                    </children>
                </HBox>
                <Button fx:id="btnCalculate" mnemonicParsing="false" onAction="#handleCalculate" text="🧮 Рассчитать прибыль" style="-fx-background-color: #2196F3; -fx-text-fill: white;" prefWidth="200.0" />
            </children>
        </VBox>

        <VBox layoutX="20.0" layoutY="260.0" spacing="10.0" style="-fx-border-color: #4CAF50; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #f9f9f9;">
            <children>
                <Label text="Результаты расчёта:">
                    <font><Font size="14.0" /></font>
                </Label>
                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Доходы:" />
                            <Label fx:id="lblTotalIncome" text="0.00 BYN" style="-fx-font-weight: bold;" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Расходы:" />
                            <Label fx:id="lblTotalExpense" text="0.00 BYN" style="-fx-font-weight: bold;" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Прибыль:" />
                            <Label fx:id="lblProfit" text="0.00 BYN" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <Button layoutX="20.0" layoutY="410.0" mnemonicParsing="false" onAction="#handleBack" text="⬅️ В главное меню" />
        <Label fx:id="lblMessage" layoutX="200.0" layoutY="415.0" textFill="RED" visible="false" />
    </children>
</AnchorPane>