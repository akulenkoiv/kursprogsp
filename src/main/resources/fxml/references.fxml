<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="500.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controllers.ReferencesController">
    <children>
        <Label layoutX="20.0" layoutY="20.0" text="Справочники">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <VBox layoutX="20.0" layoutY="80.0" spacing="15.0">
            <children>
                <Button fx:id="btnIncomeCategories" mnemonicParsing="false" onAction="#handleIncomeCategories" prefWidth="400.0" text="📋 Категории доходов" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                <Button fx:id="btnExpenseCategories" mnemonicParsing="false" onAction="#handleExpenseCategories" prefWidth="400.0" text="📋 Категории расходов" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
                <Button fx:id="btnCounterparties" mnemonicParsing="false" onAction="#handleCounterparties" prefWidth="400.0" text=" Контрагенты" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
            </children>
        </VBox>

        <Button layoutX="20.0" layoutY="340.0" mnemonicParsing="false" onAction="#handleBack" text="⬅️ В главное меню" />
    </children>
</AnchorPane>