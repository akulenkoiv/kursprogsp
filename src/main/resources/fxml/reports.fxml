<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="550.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.ReportsController">
    <children>
        <Label layoutX="20.0" layoutY="20.0" text="Отчёт о прибылях и убытках">
            <font><Font size="24.0" /></font>
        </Label>

        <VBox layoutX="20.0" layoutY="70.0" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;" prefWidth="710.0">
            <children>
                <Label text="Период отчёта:">
                    <font><Font size="14.0" /></font>
                </Label>
                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Дата начала:" />
                            <DatePicker fx:id="dpStartDate" prefWidth="200.0" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Дата окончания:" />
                            <DatePicker fx:id="dpEndDate" prefWidth="200.0" />
                        </VBox>
                    </children>
                </HBox>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnGenerate" mnemonicParsing="false" onAction="#handleGenerateReport" text="📊 Сформировать отчёт" style="-fx-background-color: #9C27B0; -fx-text-fill: white;" prefWidth="220.0" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox layoutX="20.0" layoutY="220.0" spacing="15.0" style="-fx-border-color: #4CAF50; -fx-border-radius: 5; -fx-padding: 20; -fx-background-color: #f9f9f9;" prefWidth="710.0">
            <children>
                <Label text="Финансовые показатели:">
                    <font><Font size="16.0" /></font>
                </Label>
                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                    <children>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="💰 Всего доходов:" style="-fx-font-size: 13px;" />
                            <Label fx:id="lblTotalIncome" text="0.00 BYN" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #4CAF50;" />
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="💸 Всего расходов:" style="-fx-font-size: 13px;" />
                            <Label fx:id="lblTotalExpense" text="0.00 BYN" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #f44336;" />
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="📈 Прибыль (убыток):" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label fx:id="lblProfit" text="0.00 BYN" style="-fx-font-weight: bold; -fx-font-size: 22px;" />
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="🧾 Налог (УСН 6%):" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label fx:id="lblTaxAmount" text="0.00 BYN" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #FF9800;" />
                        </VBox>
                    </children>
                </GridPane>
                <Label text="ℹ️ Нажмите 'Сформировать отчёт' для получения данных за выбранный период" style="-fx-font-size: 11px; -fx-text-fill: #999;" wrapText="true" />
            </children>
        </VBox>

        <Button layoutX="20.0" layoutY="500.0" mnemonicParsing="false" onAction="#handleBack" text="⬅️ В главное меню" />
        <Label fx:id="lblMessage" layoutX="200.0" layoutY="505.0" textFill="RED" visible="false" />
    </children>
</AnchorPane>